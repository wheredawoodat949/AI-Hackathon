# Copy to .env and fill in. .env is gitignored — NEVER commit real keys.
# Every variable here is read via python-dotenv. Empty = feature stays off
# (sponsor modules are toggled in config.yaml; these are their credentials).

# --- Hugging Face (dataset download; only needed if the dataset is gated) ---
HF_TOKEN=

# --- Basketball Path-B labeled dataset download (Roboflow Universe) ---
ROBOFLOW_API_KEY=

# --- SAM 3.1 hosted backend (only used when config.yaml sam.backend: api) ---
# Primary no-GPU SAM path: sign up at https://fal.ai, create a key. Costs
# ~$0.01/16 frames (~$0.16 for a 10s clip) — no GPU/RunPod/booth credit needed.
FAL_KEY=
# Generic hosted-API fallback (unused by the fal.ai path above).
SAM_API_URL=
SAM_API_KEY=

# --- Anthropic (build/orchestration layer; optional at runtime) ---
ANTHROPIC_API_KEY=

# --- Sentry (reliability / error + perf monitoring) ---
SENTRY_DSN=

# --- Arize (eval / observability) ---
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_DETECTION_MODEL_NAME=
ARIZE_HEALTH_MODEL_NAME=
ARIZE_MODEL_VERSION=

# --- Redis (latest track state + live Streams + portable embedding search) ---
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=sports
REDIS_TRACK_TTL_SECONDS=3600
REDIS_STREAM_MAXLEN=10000

# --- Pika (synthetic basketball review media; generated assets stay gitignored) ---
# Direct Developer API access is partner-gated. Request the API URL/key from Pika.
PIKA_API_KEY=
PIKA_API_BASE_URL=https://devapi.pika.art
PIKA_OUTPUT_DIR=

# --- Local evidence-backed tracking health report (optional JSON output) ---
TRACKING_ANALYSIS_OUTPUT=

# --- Misc ---
# Set to 1 ONLY for non-GPU smoke tests of pure-Python code (loader, config).
# Heavy runs (SAM, video) must never set this — the GPU check fails loud instead.
ALLOW_CPU=0
