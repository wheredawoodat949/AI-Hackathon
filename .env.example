# Copy to .env and fill in. .env is gitignored — NEVER commit real keys.
# Every variable here is read via python-dotenv. Empty = feature stays off
# (sponsor modules are toggled in config.yaml; these are their credentials).

# --- Hugging Face (dataset download; only needed if the dataset is gated) ---
HF_TOKEN=

# --- SAM 3.1 hosted backend (only used when config.yaml sam_backend: api) ---
SAM_API_URL=
SAM_API_KEY=

# --- Anthropic (build/orchestration layer; optional at runtime) ---
ANTHROPIC_API_KEY=

# --- Sentry (reliability / error + perf monitoring) ---
SENTRY_DSN=

# --- Arize (eval / observability) ---
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# --- Redis (vector store for semantic search) ---
REDIS_URL=redis://localhost:6379

# --- Misc ---
# Set to 1 ONLY for non-GPU smoke tests of pure-Python code (loader, config).
# Heavy runs (SAM, video) must never set this — the GPU check fails loud instead.
ALLOW_CPU=0
